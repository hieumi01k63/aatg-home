---
const steps = [
  { num: '01', title: 'Discovery', desc: 'Deep-dive into your requirements, business goals, and technical landscape.' },
  { num: '02', title: 'Planning', desc: 'Architecture design, tech stack selection, and sprint roadmap creation.' },
  { num: '03', title: 'Development', desc: 'Agile sprints with continuous integration, code reviews, and iterative delivery.' },
  { num: '04', title: 'Launch & Support', desc: 'Production deployment, monitoring setup, and ongoing maintenance partnership.' },
];
---

<section class="process section section--light">
  <div class="container">
    <div class="process__header">
      <p class="section-label reveal">How We Work</p>
      <h2 class="section-title reveal reveal-delay-1">Our Proven Process</h2>
      <p class="section-subtitle reveal reveal-delay-2">
        A streamlined, battle-tested workflow from concept to production.
      </p>
    </div>

    <div class="process__timeline">
      {steps.map((s, i) => (
        <div class={`process__step reveal reveal-delay-${i + 1}`}>
          <div class="process__step-marker">
            <span class="process__step-num">{s.num}</span>
            {i < steps.length - 1 && <div class="process__step-line" aria-hidden="true" />}
          </div>
          <div class="process__step-body">
            <h3 class="process__step-title">{s.title}</h3>
            <p class="process__step-desc">{s.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .process__header{
    text-align:center;
    margin-bottom:clamp(40px,5vw,64px);
  }
  .process__header .section-label{justify-content:center}
  .process__header .section-subtitle{margin:16px auto 0}

  .process__timeline{
    display:grid;
    grid-template-columns:repeat(4,1fr);
    gap:0;
    position:relative;
  }

  .process__step{
    text-align:center;
    position:relative;
  }

  .process__step-marker{
    display:flex;align-items:center;justify-content:center;
    position:relative;
    margin-bottom:24px;
  }

  .process__step-num{
    width:56px;height:56px;
    display:flex;align-items:center;justify-content:center;
    font-family:var(--font-display);
    font-size:.9rem;font-weight:700;
    color:var(--white);
    background:var(--navy-800);
    border-radius:50%;
    position:relative;z-index:1;
    transition:background .3s var(--ease),transform .3s var(--ease);
  }
  .process__step:hover .process__step-num{
    background:var(--orange);
    transform:scale(1.1);
  }

  .process__step-line{
    position:absolute;
    top:50%;left:calc(50% + 28px);
    width:calc(100% - 56px);
    height:2px;
    background:linear-gradient(90deg,var(--navy-800),var(--gray-200));
    /* extends into next column */
    width:calc(200% - 56px);
    left:calc(50% + 32px);
    transform:translateY(-50%);
  }

  .process__step-title{
    font-family:var(--font-display);
    font-size:1.05rem;font-weight:700;
    color:var(--navy-800);
    margin-bottom:8px;
  }
  .process__step-desc{
    font-size:.85rem;color:var(--text-light);
    line-height:1.65;
    max-width:220px;margin:0 auto;
  }

  @media(max-width:768px){
    .process__timeline{
      grid-template-columns:1fr;
      gap:32px;
    }
    .process__step{
      text-align:left;
      display:grid;
      grid-template-columns:56px 1fr;
      gap:20px;
    }
    .process__step-marker{margin-bottom:0}
    .process__step-line{
      position:absolute;
      top:calc(50% + 28px);
      left:50%;width:2px !important;
      height:calc(100% + 32px);
      transform:translateX(-50%);
      background:linear-gradient(180deg,var(--navy-800),var(--gray-200));
    }
    .process__step-desc{max-width:100%}
  }
</style>
