---
import { Icon } from 'astro-icon/components';

const values = [
  {
    icon: 'lucide:file-code-2',
    title: 'Clean Code',
    desc: 'Maintainable, well-documented codebases that your team can understand, extend, and trust.',
  },
  {
    icon: 'lucide:clock',
    title: '24/7 Support',
    desc: 'Round-the-clock availability across time zones. Your project never sleeps.',
  },
  {
    icon: 'lucide:star',
    title: 'Value for Money',
    desc: 'Top-tier engineering talent at competitive rates — maximize ROI on every sprint.',
  },
  {
    icon: 'lucide:zap',
    title: 'Faster Delivery',
    desc: 'Optimized workflows and experienced teams mean you ship features on time, every time.',
  },
];
---

<section class="values section section--light">
  <div class="container">
    <div class="values__header">
      <p class="section-label reveal">Core Values</p>
      <h2 class="section-title reveal reveal-delay-1">Built on Principles That Matter</h2>
    </div>

    <div class="values__grid">
      {values.map((v, i) => (
        <div class={`values__item reveal reveal-delay-${i + 1}`}>
          <div class="values__icon" aria-hidden="true">
            <Icon name={v.icon} size={28} />
          </div>
          <h3 class="values__title">{v.title}</h3>
          <p class="values__desc">{v.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .values__header{text-align:center;margin-bottom:clamp(40px,5vw,64px)}
  .values__header .section-label{justify-content:center}
  .values__header .section-title{margin:0 auto}

  .values__grid{
    display:grid;
    grid-template-columns:repeat(4,1fr);
    gap:var(--gap);
  }

  .values__item{
    text-align:center;
    padding:clamp(28px,3vw,40px) clamp(16px,2vw,24px);
    border-radius:8px;
    border:1px solid transparent;
    transition:background .4s var(--ease),border-color .4s var(--ease),box-shadow .4s var(--ease),transform .4s var(--ease);
  }
  .values__item:hover{
    background:var(--white);
    border-color:var(--gray-100);
    box-shadow:0 12px 40px rgba(0,0,0,.06);
    transform:translateY(-6px);
  }

  .values__icon{
    width:60px;height:60px;
    margin:0 auto 20px;
    display:flex;align-items:center;justify-content:center;
    background:var(--orange-glow);
    color:var(--orange);
    border-radius:12px;
    transition:background .3s var(--ease),color .3s var(--ease);
  }
  .values__item:hover .values__icon{
    background:var(--orange);color:var(--white);
  }

  .values__title{
    font-family:var(--font-display);
    font-size:1rem;font-weight:700;
    color:var(--navy-800);
    margin-bottom:8px;
  }
  .values__desc{
    font-size:.85rem;color:var(--text-light);line-height:1.65;
  }

  @media(max-width:900px){
    .values__grid{grid-template-columns:repeat(2,1fr)}
  }
  @media(max-width:480px){
    .values__grid{grid-template-columns:1fr}
  }
</style>
