---
const services = [
  {
    num: '01',
    title: 'Web Application Development',
    desc: 'Full-stack web solutions built with modern frameworks — React, Next.js, Node.js, and cloud-native architectures that scale.',
    tags: ['React', 'Next.js', 'Node.js', 'Cloud'],
  },
  {
    num: '02',
    title: 'Mobile App Development',
    desc: 'Native and cross-platform mobile applications for iOS and Android that deliver seamless user experiences.',
    tags: ['iOS', 'Android', 'React Native', 'Flutter'],
  },
  {
    num: '03',
    title: 'Dedicated Development Teams',
    desc: 'Extend your capacity with vetted engineers who integrate directly into your workflow, culture, and tools.',
    tags: ['Staff Aug', 'Agile', 'Full-time', 'Remote'],
  },
  {
    num: '04',
    title: 'IT Outsourcing Solutions',
    desc: 'End-to-end project delivery and managed services — from requirements through deployment and ongoing support.',
    tags: ['Managed', 'Support', 'DevOps', 'QA'],
  },
  {
    num: '05',
    title: 'Cloud & DevOps',
    desc: 'Infrastructure automation, CI/CD pipelines, and cloud migration strategies on AWS, Azure, and GCP.',
    tags: ['AWS', 'Azure', 'Docker', 'Kubernetes'],
  },
  {
    num: '06',
    title: 'UI/UX Design',
    desc: 'Research-driven design that transforms complex workflows into intuitive, visually compelling interfaces.',
    tags: ['Figma', 'Prototyping', 'Research', 'Systems'],
  },
];
---

<section class="services section section--dark" id="services">
  <div class="container">
    <div class="services__header">
      <div>
        <p class="section-label reveal">What We Do</p>
        <h2 class="section-title reveal reveal-delay-1">
          Services & Expertise
        </h2>
        <p class="section-subtitle reveal reveal-delay-2">
          Comprehensive software solutions tailored to your business needs, delivered by experienced engineering teams.
        </p>
      </div>
    </div>

    <div class="services__grid">
      {services.map((s, i) => (
        <div class={`services__card reveal reveal-delay-${(i % 3) + 1}`}>
          <span class="services__card-num">{s.num}</span>
          <h3 class="services__card-title">{s.title}</h3>
          <p class="services__card-desc">{s.desc}</p>
          <div class="services__card-tags">
            {s.tags.map((t) => (
              <span class="services__tag">{t}</span>
            ))}
          </div>
          <div class="services__card-line" aria-hidden="true"></div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .services__header{
    display:flex;justify-content:space-between;align-items:flex-end;
    margin-bottom:clamp(40px,5vw,64px);
  }

  .services__grid{
    display:grid;
    grid-template-columns:repeat(3,1fr);
    gap:2px;
  }

  .services__card{
    position:relative;
    padding:clamp(28px,3vw,40px);
    background:rgba(255,255,255,.03);
    border:1px solid rgba(255,255,255,.06);
    transition:all .4s var(--ease);
    overflow:hidden;
  }
  .services__card:hover{
    background:rgba(255,255,255,.06);
    border-color:rgba(255,106,0,.2);
    transform:translateY(-4px);
  }

  .services__card-line{
    position:absolute;bottom:0;left:0;
    width:0;height:3px;
    background:linear-gradient(90deg,var(--orange),var(--orange-light));
    transition:width .5s var(--ease);
  }
  .services__card:hover .services__card-line{width:100%}

  .services__card-num{
    font-family:var(--font-mono);
    font-size:.75rem;
    color:var(--orange);
    letter-spacing:.1em;
  }

  .services__card-title{
    font-family:var(--font-display);
    font-size:clamp(1.1rem,1.5vw,1.3rem);
    font-weight:700;color:var(--white);
    margin:16px 0 12px;
    line-height:1.3;
  }

  .services__card-desc{
    font-size:.875rem;
    color:var(--gray-400);
    line-height:1.7;
  }

  .services__card-tags{
    display:flex;flex-wrap:wrap;gap:6px;
    margin-top:20px;
  }
  .services__tag{
    font-family:var(--font-mono);
    font-size:.65rem;
    letter-spacing:.04em;
    padding:4px 10px;
    border:1px solid rgba(255,255,255,.1);
    border-radius:3px;
    color:var(--gray-400);
    text-transform:uppercase;
  }

  @media(max-width:900px){
    .services__grid{grid-template-columns:repeat(2,1fr)}
  }
  @media(max-width:560px){
    .services__grid{grid-template-columns:1fr}
  }
</style>
