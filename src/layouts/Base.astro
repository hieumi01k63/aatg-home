---
interface Props {
  title?: string;
  description?: string;
}
const title = Astro.props.title ?? 'AATG — Software Development & IT Outsourcing';
const description = Astro.props.description ?? 'Your software. Our expertise. Perfect. AATG delivers world-class software development, dedicated teams, and IT outsourcing solutions.';
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL('/og-image.png', Astro.site);
---
<!doctype html>
<html lang="en" style="color-scheme:light">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <meta name="description" content={description} />
  <title>{title}</title>

  <!-- Canonical -->
  <link rel="canonical" href={canonicalURL.href} />

  <!-- Favicon & Icons -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

  <!-- Theme color -->
  <meta name="theme-color" content="#0a0025" />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL.href} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage.href} />
  <meta property="og:site_name" content="AATG" />
  <meta property="og:locale" content="en_US" />

  <!-- Twitter / X -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage.href} />

  <!-- Structured Data: Organization -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "AATG",
    "url": "https://aatg.vn",
    "logo": "https://aatg.vn/favicon.svg",
    "description": description,
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Hanoi",
      "addressCountry": "VN"
    },
    "contactPoint": {
      "@type": "ContactPoint",
      "telephone": "+84-352-581-586",
      "email": "sayhello@aatg.company",
      "contactType": "sales"
    },
    "sameAs": []
  })} />

  <!-- Fonts: Sora (display) + DM Sans (body) + IBM Plex Mono (accents) -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <style>
    .skip-link{position:absolute;top:-100%;left:16px;z-index:9999;padding:12px 24px;background:#ff6a00;color:#fff;font-weight:600;border-radius:0 0 4px 4px;transition:top .2s}
    .skip-link:focus{top:0}
  </style>

  <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,wght@0,400;0,500;0,700;1,400&family=IBM+Plex+Mono:wght@400;500&family=Sora:wght@400;600;700;800&display=swap" />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,wght@0,400;0,500;0,700;1,400&family=IBM+Plex+Mono:wght@400;500&family=Sora:wght@400;600;700;800&display=swap" rel="stylesheet" />
</head>
<body>
  <a href="#main-content" class="skip-link">Skip to main content</a>
  <slot />

  <!-- Scroll reveal + scroll-linked effects -->
  <script>
    // === Intersection Observer for .reveal elements ===
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            e.target.classList.add('is-visible');
            observer.unobserve(e.target);
          }
        });
      },
      { threshold: 0.12 }
    );
    document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));

    // === Scroll-linked smooth effects ===
    // Elements scale up slightly and fade as they scroll through viewport
    function initScrollLinked() {
      const sections = document.querySelectorAll<HTMLElement>('.section');
      if (!sections.length) return;

      let ticking = false;

      function lerp(a: number, b: number, t: number) {
        return a + (b - a) * t;
      }

      function update() {
        const vh = window.innerHeight;
        const scrollY = window.scrollY;

        sections.forEach((section) => {
          const rect = section.getBoundingClientRect();
          const sectionTop = rect.top;
          const sectionHeight = rect.height;

          // Progress: 0 when section enters bottom, 1 when it reaches top
          const progress = 1 - (sectionTop + sectionHeight) / (vh + sectionHeight);
          const clamped = Math.max(0, Math.min(1, progress));

          // Subtle scale: 0.97 -> 1.0 -> 0.97 (peak at center)
          const centerDist = Math.abs(clamped - 0.5) * 2; // 0 at center, 1 at edges
          const scale = lerp(1, 0.975, centerDist * centerDist);

          // Subtle opacity: 0.7 -> 1.0 -> 0.7 (peak at center)
          const opacity = lerp(1, 0.82, centerDist * centerDist);

          // Only apply when section is in viewport
          if (rect.bottom > 0 && rect.top < vh) {
            section.style.transform = `scale(${scale.toFixed(4)})`;
            section.style.opacity = opacity.toFixed(3);
          } else {
            section.style.transform = '';
            section.style.opacity = '';
          }
        });

        ticking = false;
      }

      window.addEventListener('scroll', () => {
        if (!ticking) {
          ticking = true;
          requestAnimationFrame(update);
        }
      }, { passive: true });

      // Run once on load
      update();
    }

    // Only run scroll-linked effects if user hasn't set prefers-reduced-motion
    if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      initScrollLinked();
    }
  </script>
</body>
</html>
