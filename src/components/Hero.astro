---
const stats = [
  { value: '5+', label: 'Years Experience', num: 5, suffix: '+', delay: 0, duration: 1500 },
  { value: '20+', label: 'Projects Delivered', num: 20, suffix: '+', delay: 200, duration: 2200 },
  { value: '30+', label: 'Happy Clients', num: 30, suffix: '+', delay: 400, duration: 1800 },
  { value: '100%', label: 'Client Satisfaction', num: 100, suffix: '%', delay: 600, duration: 2000 },
];
---

<section class="hero">
  <!-- Parallax layers -->
  <div class="hero__grid parallax-layer" data-parallax-speed="0.15" aria-hidden="true"></div>
  <div class="hero__gradient parallax-layer" data-parallax-speed="0.08" aria-hidden="true"></div>
  <div class="hero__orb hero__orb--1 parallax-layer" data-parallax-speed="0.12" aria-hidden="true"></div>
  <div class="hero__orb hero__orb--2 parallax-layer" data-parallax-speed="0.2" aria-hidden="true"></div>

  <div class="container hero__content">
    <div class="hero__text">
      <p class="hero__label hero-entrance" data-hero-delay="0">
        <span class="hero__label-line"></span>
        Software Development & IT Outsourcing
      </p>

      <!-- Word-by-word heading reveal -->
      <h1 class="hero__heading">
        <span class="hero-word" data-hero-delay="100">We</span>
        <span class="hero-word" data-hero-delay="160">Build</span>
        <span class="hero__accent hero-word" data-hero-delay="240">Digital</span>
        <span class="hero__accent hero-word" data-hero-delay="320">Products</span>
        <span class="hero-word" data-hero-delay="400">That</span>
        <span class="hero-word" data-hero-delay="450">Drive</span>
        <span class="hero-word" data-hero-delay="510">Your</span>
        <span class="hero-word" data-hero-delay="570">Business</span>
        <span class="hero-word" data-hero-delay="640">Forward</span>
      </h1>

      <p class="hero__sub hero-entrance" data-hero-delay="500">
        From concept to deployment — our world-class engineering teams deliver scalable, high-performance software tailored to your vision.
      </p>
      <div class="hero__actions hero-entrance" data-hero-delay="650">
        <a href="#contact" class="btn btn--primary">Start Your Project</a>
        <a href="#services" class="btn btn--outline">Our Services</a>
      </div>
    </div>

    <div class="hero__stats hero-entrance" data-hero-delay="800">
      {stats.map((s) => (
        <div class="hero__stat">
          <span
            class="hero__stat-value"
            data-count-to={s.num}
            data-count-suffix={s.suffix}
            data-count-delay={s.delay}
            data-count-duration={s.duration}
          >0{s.suffix}</span>
          <span class="hero__stat-label">{s.label}</span>
        </div>
      ))}
    </div>
  </div>

  <div class="hero__scroll hero-entrance" data-hero-delay="1000" aria-hidden="true">
    <span></span>
  </div>
</section>

<style>
  .hero{
    position:relative;
    min-height:100vh;
    display:flex;align-items:center;
    background:var(--navy-900);
    overflow:hidden;
    padding-top:80px;
  }

  /* Subtle grid pattern */
  .hero__grid{
    position:absolute;inset:0;
    background-image:
      linear-gradient(rgba(255,255,255,.03) 1px,transparent 1px),
      linear-gradient(90deg,rgba(255,255,255,.03) 1px,transparent 1px);
    background-size:60px 60px;
    mask-image:radial-gradient(ellipse 70% 60% at 50% 40%,black 20%,transparent 70%);
    will-change:transform;
  }

  /* Gradient orbs */
  .hero__gradient{
    position:absolute;inset:0;
    background:
      radial-gradient(600px circle at 20% 30%,rgba(255,106,0,.08),transparent 60%),
      radial-gradient(800px circle at 80% 60%,rgba(61,26,142,.2),transparent 60%),
      radial-gradient(400px circle at 60% 20%,rgba(255,106,0,.05),transparent 50%);
    will-change:transform;
  }

  /* Floating parallax orbs */
  .hero__orb{
    position:absolute;border-radius:50%;
    filter:blur(80px);
    will-change:transform;
  }
  .hero__orb--1{
    width:400px;height:400px;
    top:10%;left:60%;
    background:rgba(255,106,0,.06);
    animation:orbFloat 8s ease-in-out infinite;
  }
  .hero__orb--2{
    width:300px;height:300px;
    bottom:15%;left:10%;
    background:rgba(61,26,142,.1);
    animation:orbFloat 10s ease-in-out infinite reverse;
  }
  @keyframes orbFloat{
    0%,100%{transform:translate(0,0)}
    50%{transform:translate(30px,-20px)}
  }

  .hero__content{
    position:relative;z-index:1;
    padding:clamp(40px,6vw,80px) 0;
  }

  .hero__label{
    font-family:var(--font-mono);
    font-size:.75rem;letter-spacing:.2em;
    text-transform:uppercase;color:var(--orange);
    display:flex;align-items:center;gap:12px;
    margin-bottom:24px;
  }
  .hero__label-line{
    width:32px;height:2px;background:var(--orange);display:block;
  }

  .hero__heading{
    font-family:var(--font-display);
    font-size:clamp(2.4rem,5.5vw,4.2rem);
    font-weight:800;line-height:1.08;
    color:var(--white);
    max-width:800px;
    letter-spacing:-.03em;
    display:flex;flex-wrap:wrap;gap:0 .28em;
  }
  .hero__accent{
    background:linear-gradient(135deg,var(--orange),var(--orange-light));
    -webkit-background-clip:text;
    -webkit-text-fill-color:transparent;
    background-clip:text;
  }

  /* Word-by-word entrance */
  .hero-word{
    display:inline-block;
    opacity:0;
    transform:translateY(30px) rotateX(40deg);
    transition:opacity .6s cubic-bezier(.22,1,.36,1),transform .6s cubic-bezier(.22,1,.36,1);
    transform-origin:bottom center;
  }
  .hero-word.is-entered{
    opacity:1;
    transform:translateY(0) rotateX(0deg);
  }

  /* Block entrance (label, subtitle, actions, stats) */
  .hero-entrance{
    opacity:0;
    transform:translateY(28px);
    transition:opacity .7s cubic-bezier(.22,1,.36,1),transform .7s cubic-bezier(.22,1,.36,1);
  }
  .hero-entrance.is-entered{
    opacity:1;
    transform:translateY(0);
  }

  .hero__sub{
    font-size:clamp(1rem,1.5vw,1.15rem);
    color:var(--gray-200);
    max-width:560px;
    margin-top:24px;
    line-height:1.75;
  }

  .hero__actions{
    display:flex;flex-wrap:wrap;gap:16px;
    margin-top:40px;
  }

  /* Stats bar */
  .hero__stats{
    display:grid;
    grid-template-columns:repeat(4,1fr);
    gap:0;
    margin-top:clamp(50px,6vw,80px);
    border:1px solid rgba(255,255,255,.08);
    border-radius:8px;
    overflow:hidden;
    background:rgba(255,255,255,.02);
    backdrop-filter:blur(4px);
  }
  .hero__stat{
    padding:clamp(20px,2.5vw,32px) clamp(16px,2vw,28px);
    text-align:center;
    border-right:1px solid rgba(255,255,255,.08);
  }
  .hero__stat:last-child{border-right:none}

  .hero__stat-value{
    display:block;
    font-family:var(--font-display);
    font-size:clamp(1.8rem,3vw,2.6rem);
    font-weight:800;color:var(--orange);
    letter-spacing:-.02em;
    font-variant-numeric:tabular-nums;
  }
  .hero__stat-label{
    display:block;
    font-size:.78rem;letter-spacing:.06em;
    text-transform:uppercase;
    color:var(--gray-400);
    margin-top:6px;
  }

  /* Scroll indicator */
  .hero__scroll{
    position:absolute;bottom:32px;left:50%;
    transform:translateX(-50%);
  }
  .hero__scroll.is-entered{
    transform:translateX(-50%);
  }
  .hero__scroll span{
    display:block;width:20px;height:32px;
    border:2px solid rgba(255,255,255,.2);
    border-radius:12px;
    position:relative;
  }
  .hero__scroll span::after{
    content:'';position:absolute;
    top:6px;left:50%;transform:translateX(-50%);
    width:3px;height:8px;border-radius:3px;
    background:var(--orange);
    animation:scrollPulse 1.8s ease-in-out infinite;
  }

  @keyframes scrollPulse{
    0%,100%{opacity:1;transform:translateX(-50%) translateY(0)}
    50%{opacity:.3;transform:translateX(-50%) translateY(10px)}
  }

  @media(max-width:768px){
    .hero__stats{grid-template-columns:repeat(2,1fr)}
    .hero__stat:nth-child(2){border-right:none}
    .hero__stat:nth-child(1),.hero__stat:nth-child(2){
      border-bottom:1px solid rgba(255,255,255,.08);
    }
  }
</style>

<script>
  // === 1. Staggered hero entrance (words + blocks) ===
  function runHeroEntrance() {
    const words = document.querySelectorAll<HTMLElement>('.hero-word');
    const blocks = document.querySelectorAll<HTMLElement>('.hero-entrance');

    words.forEach((w) => {
      const delay = parseInt(w.dataset.heroDelay || '0', 10);
      setTimeout(() => w.classList.add('is-entered'), 300 + delay);
    });

    blocks.forEach((b) => {
      const delay = parseInt(b.dataset.heroDelay || '0', 10);
      setTimeout(() => b.classList.add('is-entered'), 300 + delay);
    });
  }

  // === 2. Counter animation (with per-stat delay & duration) ===
  function animateCounters() {
    const counters = document.querySelectorAll<HTMLElement>('[data-count-to]');

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          const el = entry.target as HTMLElement;
          observer.unobserve(el);

          const target = parseInt(el.dataset.countTo || '0', 10);
          const suffix = el.dataset.countSuffix || '';
          const delay = parseInt(el.dataset.countDelay || '0', 10);
          const duration = parseInt(el.dataset.countDuration || '2000', 10);

          function easeOutExpo(t: number) {
            return t === 1 ? 1 : 1 - Math.pow(2, -10 * t);
          }

          function startCount() {
            const startTime = performance.now();

            function tick(now: number) {
              const elapsed = now - startTime;
              const progress = Math.min(elapsed / duration, 1);
              const value = Math.round(easeOutExpo(progress) * target);
              el.textContent = value + suffix;
              if (progress < 1) requestAnimationFrame(tick);
            }

            requestAnimationFrame(tick);
          }

          if (delay > 0) {
            setTimeout(startCount, delay);
          } else {
            startCount();
          }
        });
      },
      { threshold: 0.3 }
    );

    counters.forEach((c) => observer.observe(c));
  }

  // === 3. Parallax on hero layers ===
  function initParallax() {
    const layers = document.querySelectorAll<HTMLElement>('.parallax-layer');
    if (!layers.length) return;

    // Use passive listener + rAF for performance
    let ticking = false;
    function onScroll() {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => {
        const scrollY = window.scrollY;
        layers.forEach((layer) => {
          const speed = parseFloat(layer.dataset.parallaxSpeed || '0');
          layer.style.transform = `translate3d(0, ${scrollY * speed}px, 0)`;
        });
        ticking = false;
      });
    }

    window.addEventListener('scroll', onScroll, { passive: true });
  }

  // Boot
  runHeroEntrance();
  animateCounters();
  initParallax();
</script>
