---
const links = [
  { label: 'About', href: '#about' },
  { label: 'Services', href: '#services' },
  { label: 'Industries', href: '#industries' },
  { label: 'Why Us', href: '#why-us' },
  { label: 'Contact', href: '#contact' },
];

import Logo from '@/components/Logo.astro';
---

<header class="navbar" id="navbar">
  <div class="container navbar__inner">
    <a href="/" class="navbar__logo" aria-label="AATG Home">
      <Logo width={160} theme="dark" />
    </a>

    <nav class="navbar__nav" id="nav-menu">
      {links.map((l) => (
        <a href={l.href} class="navbar__link">{l.label}</a>
      ))}
    </nav>

    <a href="#contact" class="btn btn--primary navbar__cta">Get Started</a>

    <button class="navbar__burger" id="burger" aria-label="Toggle menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<!-- Mobile Drawer (outside header to avoid layout interference) -->
<div class="drawer-overlay" id="drawer-overlay"></div>
<div class="drawer" id="drawer">
  <div class="drawer__header">
    <a href="/" class="navbar__logo" aria-label="AATG Home">
      <Logo width={140} theme="dark" />
    </a>
    <button class="drawer__close" id="drawer-close" aria-label="Close menu">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
  </div>
  <nav class="drawer__nav">
    {links.map((l, i) => (
      <a href={l.href} class="drawer__link" style={`--i:${i}`}>{l.label}</a>
    ))}
  </nav>
  <div class="drawer__footer" style={`--i:${links.length}`}>
    <a href="#contact" class="btn btn--primary drawer__cta">Get Started</a>
  </div>
</div>

<style>
  .navbar{
    position:fixed;top:0;left:0;right:0;z-index:1000;
    padding:0 0;
    background:transparent;
    transition:background .35s var(--ease),box-shadow .35s var(--ease),padding .35s var(--ease);
  }
  .navbar.is-scrolled{
    background:rgba(10,0,37,.95);
    backdrop-filter:blur(12px);
    box-shadow:0 2px 40px rgba(0,0,0,.25);
  }
  .navbar__inner{
    display:flex;align-items:center;justify-content:space-between;
    height:80px;
  }
  .navbar__logo{
    display:flex;align-items:center;gap:4px;
    font-family:var(--font-display);font-weight:800;font-size:1.5rem;
    color:var(--white);letter-spacing:-.02em;
  }
  .navbar__logo-dot{
    width:8px;height:8px;border-radius:50%;
    background:var(--orange);display:inline-block;
    margin-top:6px;
  }
  .navbar__nav{display:flex;gap:clamp(20px,3vw,40px)}
  .navbar__link{
    font-family:var(--font-display);
    font-size:.82rem;font-weight:600;
    letter-spacing:.06em;text-transform:uppercase;
    color:rgba(255,255,255,.7);
    padding:6px 0;
    position:relative;
    transition:color .3s var(--ease);
  }
  .navbar__link::after{
    content:'';position:absolute;bottom:0;left:0;
    width:0;height:2px;background:var(--orange);
    transition:width .3s var(--ease);
  }
  .navbar__link:hover,.navbar__link:focus-visible{color:var(--white)}
  .navbar__link:hover::after,.navbar__link:focus-visible::after{width:100%}
  .navbar__link:focus-visible{outline:none}

  .navbar__cta{padding:10px 24px;font-size:.78rem}

  .navbar__burger{
    display:none;flex-direction:column;gap:5px;
    width:28px;padding:4px 0;
  }
  .navbar__burger:focus-visible{
    outline:2px solid var(--orange);
    outline-offset:4px;
    border-radius:2px;
  }
  .navbar__burger span{
    display:block;width:100%;height:2px;background:var(--white);
    border-radius:2px;transition:transform .3s var(--ease),opacity .3s var(--ease);
    -webkit-appearance:none;
  }

  /* ── Drawer (mobile only) ── */
  .drawer-overlay,.drawer,.drawer__header,.drawer__nav,.drawer__footer,.drawer__close{
    display:none;
  }

  @media(max-width:900px){
    .navbar__nav,.navbar__cta{display:none}
    .navbar__burger{display:flex}

    .drawer-overlay{
      display:block;
      position:fixed;inset:0;z-index:1001;
      background:rgba(0,0,0,.5);
      backdrop-filter:blur(4px);
      opacity:0;pointer-events:none;
      transition:opacity .35s var(--ease);
    }
    .drawer-overlay.is-active{
      opacity:1;pointer-events:auto;
    }

    .drawer{
      display:flex;flex-direction:column;
      position:fixed;top:0;right:0;bottom:0;z-index:1002;
      width:min(320px, 85vw);
      background:rgba(10,0,37,.98);
      backdrop-filter:blur(20px);
      border-left:1px solid rgba(255,255,255,.06);
      transform:translateX(100%);
      transition:transform .4s cubic-bezier(.22,1,.36,1);
      overflow-y:auto;
    }
    .drawer.is-open{
      transform:translateX(0);
    }

    .drawer__header{
      display:flex;align-items:center;justify-content:space-between;
      padding:20px 24px;
      border-bottom:1px solid rgba(255,255,255,.06);
    }
    .drawer__close{
      display:flex;align-items:center;justify-content:center;
      width:40px;height:40px;
      color:rgba(255,255,255,.6);
      border-radius:8px;
      transition:color .2s,background .2s;
    }
    .drawer__close:hover{
      color:var(--white);
      background:rgba(255,255,255,.08);
    }

    .drawer__nav{
      display:flex;flex-direction:column;
      padding:16px 24px;flex:1;
    }
    .drawer__link{
      font-family:var(--font-display);
      font-size:1rem;font-weight:600;
      letter-spacing:.04em;text-transform:uppercase;
      color:rgba(255,255,255,.6);
      padding:18px 0;
      border-bottom:1px solid rgba(255,255,255,.05);
      position:relative;
      transition:color .25s var(--ease);
      /* stagger animation */
      opacity:0;
      transform:translateX(24px);
    }
    .drawer.is-open .drawer__link{
      opacity:1;
      transform:translateX(0);
      transition:color .25s var(--ease),
                 opacity .4s cubic-bezier(.22,1,.36,1) calc(.15s + var(--i) * .06s),
                 transform .4s cubic-bezier(.22,1,.36,1) calc(.15s + var(--i) * .06s);
    }
    .drawer__link:last-child{border-bottom:none}
    .drawer__link:hover,.drawer__link:focus-visible{
      color:var(--white);
    }
    .drawer__link::before{
      content:'';position:absolute;left:-24px;top:50%;
      width:3px;height:0;
      background:var(--orange);border-radius:2px;
      transform:translateY(-50%);
      transition:height .25s var(--ease);
    }
    .drawer__link:hover::before{height:24px}

    .drawer__footer{
      display:block;
      padding:16px 24px 32px;
      /* stagger with items */
      opacity:0;
      transform:translateX(24px);
    }
    .drawer.is-open .drawer__footer{
      opacity:1;
      transform:translateX(0);
      transition:opacity .4s cubic-bezier(.22,1,.36,1) calc(.15s + var(--i) * .06s),
                 transform .4s cubic-bezier(.22,1,.36,1) calc(.15s + var(--i) * .06s);
    }
    .drawer__cta{
      display:block;width:100%;text-align:center;
      padding:14px 24px;font-size:.85rem;
    }

    /* Burger → X animation */
    .navbar__burger.is-active span:nth-child(1){
      transform:translateY(7px) rotate(45deg);
    }
    .navbar__burger.is-active span:nth-child(2){
      opacity:0;
    }
    .navbar__burger.is-active span:nth-child(3){
      transform:translateY(-7px) rotate(-45deg);
    }
  }
</style>

<script>
  const navbar = document.getElementById('navbar')!;
  const burger = document.getElementById('burger')!;
  const drawer = document.getElementById('drawer')!;
  const overlay = document.getElementById('drawer-overlay')!;
  const drawerClose = document.getElementById('drawer-close')!;

  window.addEventListener('scroll', () => {
    navbar.classList.toggle('is-scrolled', window.scrollY > 60);
  });

  function openDrawer() {
    drawer.classList.add('is-open');
    overlay.classList.add('is-active');
    burger.classList.add('is-active');
    burger.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  }

  function closeDrawer() {
    drawer.classList.remove('is-open');
    overlay.classList.remove('is-active');
    burger.classList.remove('is-active');
    burger.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  }

  burger.addEventListener('click', () => {
    drawer.classList.contains('is-open') ? closeDrawer() : openDrawer();
  });

  drawerClose.addEventListener('click', closeDrawer);
  overlay.addEventListener('click', closeDrawer);

  // Close drawer on link click
  drawer.querySelectorAll('a').forEach((a) =>
    a.addEventListener('click', closeDrawer)
  );

  // Close on Escape key
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && drawer.classList.contains('is-open')) closeDrawer();
  });
</script>
