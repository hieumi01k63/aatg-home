---
import { Icon } from 'astro-icon/components';

const highlights = [
  { icon: 'lucide:repeat', title: 'Agile Methodology', desc: 'Iterative development with continuous feedback loops for rapid, reliable delivery.' },
  { icon: 'lucide:blocks', title: 'Scalable Architecture', desc: 'Systems designed to grow with your business — from startup to enterprise scale.' },
  { icon: 'lucide:shield-check', title: 'Quality First', desc: 'Rigorous code review, automated testing, and CI/CD pipelines on every project.' },
];
---

<section class="about section" id="about">
  <div class="container about__grid">
    <div class="about__visual reveal">
      <div class="about__card">
        <div class="about__card-accent" aria-hidden="true"></div>
        <div class="about__card-inner">
          <span class="about__card-number">5+</span>
          <span class="about__card-text">Years crafting<br/>digital excellence</span>
        </div>
      </div>
      <div class="about__dots" aria-hidden="true"></div>
    </div>

    <div class="about__content">
      <p class="section-label reveal">Who We Are</p>
      <h2 class="section-title reveal reveal-delay-1">
        A Vietnam-Based Team With <span style="color:var(--orange)">Global Standards</span>
      </h2>
      <p class="section-subtitle reveal reveal-delay-2">
        AATG is a software development and IT outsourcing company headquartered in Vietnam. We combine deep technical expertise with a commitment to understanding your business, delivering solutions that are not just functional — but transformative.
      </p>

      <div class="about__highlights">
        {highlights.map((h, i) => (
          <div class={`about__highlight reveal reveal-delay-${i + 2}`}>
            <span class="about__highlight-icon" aria-hidden="true">
              <Icon name={h.icon} size={22} />
            </span>
            <div>
              <h3 class="about__highlight-title">{h.title}</h3>
              <p class="about__highlight-desc">{h.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .about__grid{
    display:grid;
    grid-template-columns:1fr 1.2fr;
    gap:clamp(40px,6vw,80px);
    align-items:center;
  }

  /* Visual card */
  .about__visual{position:relative}
  .about__card{
    position:relative;
    background:var(--navy-800);
    border-radius:12px;
    padding:clamp(40px,4vw,60px);
    overflow:hidden;
  }
  .about__card-accent{
    position:absolute;top:0;right:0;
    width:120px;height:120px;
    background:var(--orange);
    border-radius:0 12px 0 100%;
    opacity:.9;
  }
  .about__card-inner{position:relative;z-index:1}
  .about__card-number{
    display:block;
    font-family:var(--font-display);
    font-size:clamp(4rem,8vw,7rem);
    font-weight:800;color:var(--white);
    line-height:1;letter-spacing:-.04em;
  }
  .about__card-text{
    display:block;margin-top:12px;
    font-size:1.1rem;color:var(--gray-200);
    line-height:1.5;
  }

  .about__dots{
    position:absolute;bottom:-20px;right:-20px;
    width:100px;height:100px;
    background-image:radial-gradient(var(--orange) 1.5px,transparent 1.5px);
    background-size:12px 12px;
    opacity:.3;
  }

  /* Highlights */
  .about__highlights{
    display:flex;flex-direction:column;gap:20px;
    margin-top:36px;
  }
  .about__highlight{
    display:flex;gap:16px;align-items:flex-start;
    padding:16px;
    border-radius:8px;
    transition:background .3s var(--ease);
  }
  .about__highlight:hover{background:var(--gray-50)}
  .about__highlight-icon{
    flex-shrink:0;
    width:44px;height:44px;
    display:flex;align-items:center;justify-content:center;
    background:var(--orange-glow);
    color:var(--orange);
    border-radius:8px;
  }
  .about__highlight-title{
    font-family:var(--font-display);
    font-size:.95rem;font-weight:700;
    color:var(--navy-800);
    margin-bottom:4px;
  }
  .about__highlight-desc{
    font-size:.85rem;color:var(--text-light);line-height:1.6;
  }

  @media(max-width:768px){
    .about__grid{grid-template-columns:1fr;gap:40px}
    .about__visual{order:2}
  }
</style>
